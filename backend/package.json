{
  "name": "fpom-rewards-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "node scripts/run-tests.mjs",
    "logs": "tsx scripts/show-logs.ts",
    "stats": "tsx scripts/show-stats.ts",
    "admin:links": "tsx scripts/admin-links.ts",
    "prisma:sync": "prisma db push --skip-generate",
    "prisma:sync:test": "node scripts/run-tests.mjs --sync-only",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@massalabs/massa-web3": "^5.3.0",
    "@prisma/client": "^5.22.0",
    "fastify": "^5.1.0",
    "pino-pretty": "^13.0.0",
    "tslib": "^2.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
